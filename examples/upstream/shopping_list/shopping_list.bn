-- Shopping List

store: [
    elements: [item_input: SOURCE, clear_button: SOURCE]

    text_to_add: elements.item_input.event.key_down.key |> WHEN {
        Enter => BLOCK {
            trimmed: elements.item_input.text |> Text/trim()

            trimmed
            |> Text/is_not_empty()
            |> WHEN {
                True => trimmed
                False => SKIP
            }
        }

        __ => SKIP
    }

    items: LIST {}
    |> List/append(item: text_to_add)
    |> List/clear(on: elements.clear_button.event.press)
]

document: Document/new(root: root_element(PASS: [store: store]))

FUNCTION root_element() {
    Element/stripe(
        element: []
        direction: Column
        gap: 16
        style: [padding: 20, width: 400]

        items: LIST {
            header()
            item_input() |> SOURCE { PASSED.store.elements.item_input }
            items_list()
            footer()
        }
    )
}

FUNCTION header() {
    Element/label(
        element: []
        style: [font: [size: 24, weight: Bold]]
        label: TEXT { Shopping List }
    )
}

FUNCTION item_input() {
    Element/text_input(
        element: [event: [key_down: SOURCE, change: SOURCE]]
        style: [width: Fill]
        label: Hidden[text: TEXT { Item name }]

        text: LATEST {
            Text/empty()
            element.event.change.text
            PASSED.store.text_to_add |> THEN { Text/empty() }
        }

        placeholder: [text: TEXT { Type and press Enter to add... }]
        focus: True
    )
}

FUNCTION items_list() {
    Element/stripe(
        element: []
        direction: Column
        gap: 4
        style: []

        items: PASSED.store.items |> List/map(
            item

            new: Element/label(
                element: []
                style: [font: [color: White]]
                label: TEXT { - {item} }
            )
        )
    )
}

FUNCTION footer() {
    Element/stripe(
        element: []
        direction: Row
        gap: 16
        style: []

        items: LIST {
            item_count_label()
            clear_button() |> SOURCE { PASSED.store.elements.clear_button }
        }
    )
}

FUNCTION item_count_label() {
    Element/label(
        element: []
        style: [font: [color: Oklch[lightness: 0.5]]]

        label: BLOCK {
            count: PASSED.store.items |> List/count()

            TEXT { {count} items }
        }
    )
}

FUNCTION clear_button() {
    Element/button(
        element: [event: [press: SOURCE]]
        style: [padding: 10]
        label: TEXT { Clear }
    )
}
