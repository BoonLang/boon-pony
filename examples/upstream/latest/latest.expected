# Latest example - most recent button press wins

[test]
category = "interactive"
description = "LATEST updates to the most recent button value"

[output]
text = "Send 1Send 23Sum: 3"

[timing]
timeout = 5000
poll_interval = 200

[[sequence]]
description = "Click Send 1"
actions = [["click_button", 0]]
expect = "Send 1Send 21Sum: 1"

[[sequence]]
description = "Click Send 2"
actions = [["click_button", 1]]
expect = "Send 1Send 22Sum: 2"
