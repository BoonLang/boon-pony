-- Timer (7GUIs Task 4)
-- Elapsed time gauge, numeric display, adjustable duration, reset.

tick: Duration[milliseconds: 100] |> Timer/interval()

store: [
    elements: [
        duration_slider: SOURCE
        reset_button: SOURCE
    ]

    max_duration: 15 |> HOLD state {
        elements.duration_slider.event.change.value
    }

    -- Raw elapsed: increments on tick, reset sets to 0.
    -- Capped by Math/min in `elapsed` for display.
    raw_elapsed: 0 |> HOLD state {
        LATEST {
            tick |> THEN { state + 0.1 }
            elements.reset_button.event.press |> THEN { 0 }
        }
    }

    -- Capped elapsed for display (never exceeds max_duration)
    elapsed: raw_elapsed |> Math/min(b: max_duration)

    -- Display value: round to 1 decimal place
    elapsed_tenths: elapsed * 10 |> Math/round()
    elapsed_display: elapsed_tenths / 10

    -- Progress percentage (0 to 100)
    progress_percent: elapsed / max_duration * 100
        |> Math/min(b: 100)
        |> Math/round()
]

document: Document/new(root: root_element(PASS: [store: store]))

FUNCTION root_element() {
    BLOCK {
        elapsed_display: PASSED.store.elapsed_display
        max_duration: PASSED.store.max_duration
        progress_percent: PASSED.store.progress_percent

        Element/stripe(
            element: []
            direction: Column
            gap: 16
            style: [padding: 20, width: 400]

            items: LIST {
                Element/label(
                    element: []
                    style: [font: [size: 22, weight: Bold]]
                    label: TEXT { Timer }
                )
                gauge_row(PASS: [progress_percent: progress_percent])
                elapsed_row(PASS: [elapsed_display: elapsed_display])
                duration_row(PASS: [store: PASSED.store, max_duration: max_duration])
                Element/button(
                    element: [event: [press: SOURCE]]
                    style: [width: Fill]
                    label: TEXT { Reset }
                ) |> SOURCE { PASSED.store.elements.reset_button }
            }
        )
    }
}

FUNCTION gauge_row() {
    BLOCK {
        progress_percent: PASSED.progress_percent
        Element/stripe(
            element: []
            direction: Row
            gap: 10
            style: []

            items: LIST {
                Element/label(element: [], style: [], label: TEXT { Elapsed Time: })
                Element/label(
                    element: []
                    style: []
                    label: TEXT { {progress_percent}% }
                )
            }
        )
    }
}

FUNCTION elapsed_row() {
    BLOCK {
        elapsed_display: PASSED.elapsed_display
        Element/stripe(
            element: []
            direction: Row
            gap: 10
            style: []

            items: LIST {
                Element/label(
                    element: []
                    style: []
                    label: TEXT { {elapsed_display}s }
                )
            }
        )
    }
}

FUNCTION duration_row() {
    BLOCK {
        max_duration: PASSED.max_duration

        Element/stripe(
            element: []
            direction: Row
            gap: 10
            style: []

            items: LIST {
                Element/label(element: [], style: [], label: TEXT { Duration: })
                Element/slider(
                    element: [event: [change: SOURCE]]
                    style: [width: 200]
                    label: Hidden[text: TEXT { Duration }]
                    value: max_duration
                    min: 1
                    max: 30
                    step: 0.1
                ) |> SOURCE { PASSED.store.elements.duration_slider }
                Element/label(
                    element: []
                    style: []
                    label: TEXT { {max_duration}s }
                )
            }
        )
    }
}
