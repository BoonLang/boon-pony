-- Circle Drawer (7GUIs Task 6)
-- Click canvas to create circles. Undo removes last circle.

store: [
    elements: [
        canvas: SOURCE
        undo_button: SOURCE
    ]

    circles: LIST {}
        |> List/append(on: elements.canvas.event.click |> WHEN {
            click => [x: click.x, y: click.y]
        })
        |> List/remove_last(on: elements.undo_button.event.press)

    count: circles |> List/count()
]

document: Document/new(root: root_element(PASS: [store: store]))

FUNCTION root_element() {
    BLOCK {
        store: PASSED.store

        Element/stripe(
            element: []
            direction: Column
            gap: 12
            style: [padding: 20, width: 500]

            items: LIST {
                Element/label(
                    element: []
                    style: [font: [size: 22, weight: Bold]]
                    label: TEXT { Circle Drawer }
                )
                Element/stripe(
                    element: []
                    direction: Row
                    gap: 10
                    style: []
                    items: LIST {
                        Element/button(
                            element: [event: [press: SOURCE]]
                            style: []
                            label: TEXT { Undo }
                        ) |> SOURCE { store.elements.undo_button }
                        Element/label(
                            element: []
                            style: []
                            label: TEXT { Circles: {store.count} }
                        )
                    }
                )
                Element/svg(
                    element: [event: [click: SOURCE]]
                    style: [width: 460, height: 300, background: TEXT { rgba(255,255,255,0.1) }]
                    children: store.circles |> List/map(item, new:
                        Element/svg_circle(
                            element: []
                            cx: item.x
                            cy: item.y
                            r: 20
                            style: [
                                fill: TEXT { #3498db }
                                stroke: TEXT { #2c3e50 }
                                stroke_width: 2
                            ]
                        )
                    )
                ) |> SOURCE { store.elements.canvas }
            }
        )
    }
}
