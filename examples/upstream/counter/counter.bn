document: Document/new(root: Element/stripe(
    element: []
    direction: Column
    gap: 0
    style: []

    items: LIST {
        counter
        increment_button
    }
))

counter:
    LATEST {
        0
        increment_button.event.press |> THEN { 1 }
    }
    |> Math/sum()

increment_button: Element/button(
    element: [event: [press: SOURCE]]
    style: []
    label: TEXT { + }
)
