-- Test: Do multiple buttons have independent click states?
-- Click-based version of button_hover_test for easier automated testing
-- Background and outline now react to state changes

store: [
    btn_a: make_button(name: TEXT { A })
    btn_b: make_button(name: TEXT { B })
    btn_c: make_button(name: TEXT { C })
]

FUNCTION make_button(name) {
    [
        elements: [button: SOURCE]
        name: name

        clicked: False |> HOLD state {
            elements.button.event.press |> THEN { state |> Bool/not() }
        }
    ]
}

document: Document/new(root: Element/stripe(
    element: []
    direction: Column
    gap: 20
    style: [padding: 20]

    items: LIST {
        Element/label(
            element: []
            style: []
            label: TEXT { Click each button - clicked ones turn darker with outline }
        )

        Element/stripe(
            element: []
            direction: Row
            gap: 10
            style: []

            items: LIST {
                Element/button(
                    element: [event: [press: SOURCE]]

                    style: [
                        padding: [row: 20, column: 10]
                        rounded_corners: 5

                        background: [
                            color: store.btn_a.clicked |> WHILE {
                                True => Oklch[lightness: 0.35, chroma: 0.1, hue: 25]
                                False => Oklch[lightness: 0.25]
                            }
                        ]

                        font: [color: White]

                        outline: store.btn_a.clicked |> WHILE {
                            True => [
                                thickness: 2
                                color: Oklch[lightness: 0.6, chroma: 0.25, hue: 25]
                            ]

                            False => NoOutline
                        }
                    ]

                    label: TEXT { Button {store.btn_a.name} }
                )
                |> SOURCE { store.btn_a.elements.button }

                Element/button(
                    element: [event: [press: SOURCE]]

                    style: [
                        padding: [row: 20, column: 10]
                        rounded_corners: 5

                        background: [
                            color: store.btn_b.clicked |> WHILE {
                                True => Oklch[lightness: 0.35, chroma: 0.1, hue: 25]
                                False => Oklch[lightness: 0.25]
                            }
                        ]

                        font: [color: White]

                        outline: store.btn_b.clicked |> WHILE {
                            True => [
                                thickness: 2
                                color: Oklch[lightness: 0.6, chroma: 0.25, hue: 25]
                            ]

                            False => NoOutline
                        }
                    ]

                    label: TEXT { Button {store.btn_b.name} }
                )
                |> SOURCE { store.btn_b.elements.button }

                Element/button(
                    element: [event: [press: SOURCE]]

                    style: [
                        padding: [row: 20, column: 10]
                        rounded_corners: 5

                        background: [
                            color: store.btn_c.clicked |> WHILE {
                                True => Oklch[lightness: 0.35, chroma: 0.1, hue: 25]
                                False => Oklch[lightness: 0.25]
                            }
                        ]

                        font: [color: White]

                        outline: store.btn_c.clicked |> WHILE {
                            True => [
                                thickness: 2
                                color: Oklch[lightness: 0.6, chroma: 0.25, hue: 25]
                            ]

                            False => NoOutline
                        }
                    ]

                    label: TEXT { Button {store.btn_c.name} }
                )
                |> SOURCE { store.btn_c.elements.button }
            }
        )

        Element/label(element: [], style: [], label: TEXT {
            States - A: {store.btn_a.clicked}, B: {store.btn_b.clicked}, C: {store.btn_c.clicked}
        })
    }
))
