# Independent click-state buttons example

[test]
category = "interactive"
description = "Each button toggles its own state independently"

[output]
text = "Click each button - clicked ones turn darker with outlineButton AButton BButton CStates - A: False, B: False, C: False"

[timing]
timeout = 5000
poll_interval = 200

[[sequence]]
description = "Click Button A"
actions = [["click_button", 0]]
expect = "Click each button - clicked ones turn darker with outlineButton AButton BButton CStates - A: True, B: False, C: False"

[[sequence]]
description = "Click Button C"
actions = [["click_button", 2]]
expect = "Click each button - clicked ones turn darker with outlineButton AButton BButton CStates - A: True, B: False, C: True"

[[sequence]]
description = "Click Button A again without affecting B or C"
actions = [["click_button", 0]]
expect = "Click each button - clicked ones turn darker with outlineButton AButton BButton CStates - A: False, B: False, C: True"
