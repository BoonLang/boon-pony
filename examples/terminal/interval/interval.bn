sources: [
  frame: [event: [tick: SOURCE]]
]

tick: Duration[seconds: 1] |> Timer/interval()

counter:
  0 |> HOLD count {
    tick |> THEN { count + 1 }
  }

document: Terminal/canvas(width: 80, height: 24, items: LIST {
  Canvas/text(x: 2, y: 2, text: TEXT { Interval: {counter} })
  Canvas/text(x: 2, y: 4, text: TEXT { Timer/interval })
})
