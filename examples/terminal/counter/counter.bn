sources: [
  keyboard: [event: [key_down: SOURCE]]
  frame: [event: [tick: SOURCE]]
]

counter:
  0 |> HOLD count {
    sources.keyboard.event.key_down.key
      |> WHEN { Enter => count + 1 __ => SKIP }
  }

document: Terminal/canvas(width: 80, height: 24, items: LIST {
  Canvas/text(x: 2, y: 2, text: TEXT { Counter: {counter} })
  Canvas/rect(x: 2, y: 4, width: 5, height: 1, glyph: TEXT { + })
  Canvas/text(x: 8, y: 4, text: TEXT { Enter increments })
})
